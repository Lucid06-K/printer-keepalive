# pkeep — control the printer nozzle keep-alive launchd agent.
#
# Run bare for an interactive UI (↑/↓ to move, enter to select, q to quit).
# Scriptable subcommands:
#   pkeep on|off            enable/disable the scheduled keep-alive
#   pkeep status            one-shot text status
#   pkeep run [tier]        print now (light|medium|heavy; default auto)
#   pkeep preview [tier]    build + open the page PDF without printing
#   pkeep render            render the page to a PNG (in ~/Downloads) and open it
#   pkeep log [n]           last n history lines (default 15)
#   pkeep notify on|off     toggle the heads-up notification
#   pkeep printer           list selected printers
#   pkeep printer NAME      set the list to just NAME
#   pkeep printer add NAME  add a printer to the cycle
#   pkeep printer rm NAME   remove a printer from the cycle
#   pkeep interval [days]   show / set the schedule interval
#   pkeep lead [secs]       show / set the heads-up lead time
#   pkeep notepaper STYLE   note paper below the strip: off|lines|grid|dots
#   pkeep notespacing MM    rule/grid spacing in millimetres (4-30)
#   pkeep margin on|off     workbook-style left margin line
#   pkeep marginmm MM       margin line distance from the left edge (10-80)
#   pkeep art off|rotate|N  corner ASCII art: off, rotate all 15, or pin #N
#   pkeep artsheet          print a gallery of all 15 art pieces
#   pkeep update            fetch + verify + install the latest version
#   pkeep autoupdate on|off opt-in daily auto-update
#
# The worker lives in printer-keepalive.sh next to this file (installed copy:
# ~/Library/Scripts/printer-keepalive.sh).

LABEL="com.printer-keepalive.agent"
TARGET="gui/$(id -u)/$LABEL"
PLIST="$HOME/Library/LaunchAgents/$LABEL.plist"
SCRIPTS="$HOME/Library/Scripts"
WORKER="$SCRIPTS/printer-keepalive.sh"
[ -x "$WORKER" ] || WORKER="$(cd "$(dirname "$0")" && pwd)/printer-keepalive.sh"
LOG="$HOME/Library/Logs/printer-keepalive.log"

PRINTER_FILE="$SCRIPTS/printer_keepalive.printer"
INTERVAL_FILE="$SCRIPTS/printer_keepalive.interval"
LEAD_FILE="$SCRIPTS/printer_keepalive.lead"
NONOTIFY_FLAG="$SCRIPTS/printer_keepalive.nonotify"
LINES_FLAG="$SCRIPTS/printer_keepalive.lines"
NOTESTYLE_FILE="$SCRIPTS/printer_keepalive.notestyle"
NOTESPACING_FILE="$SCRIPTS/printer_keepalive.notespacing"
MARGIN_FLAG="$SCRIPTS/printer_keepalive.margin"
MARGINMM_FILE="$SCRIPTS/printer_keepalive.marginmm"
ARTFLAG="$SCRIPTS/printer_keepalive.art"
LASTPRINT_FILE="$SCRIPTS/printer_keepalive.lastprint"
HISTORY_FILE="$SCRIPTS/printer_keepalive.history"

# auto-update (opt-in): checks at most once a day when the menu opens
AUTOUPDATE_FLAG="$SCRIPTS/printer_keepalive.autoupdate"
UPDATE_STAMP="$SCRIPTS/.printer_keepalive.update_check"
WORKER_DEST="$SCRIPTS/printer-keepalive.sh"   # where the worker is installed
SELF_DEST="$SCRIPTS/pkeep"                     # where this control script is installed
REPO_RAW="https://raw.githubusercontent.com/Lucid06-K/printer-keepalive/main"

DEFAULT_INTERVAL=1209600
DEFAULT_LEAD=8
VERSION="1.14.2"

